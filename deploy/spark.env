# Spark configuration
# Uncomment and modify values as needed.

# NATS server URL
SPARK_NATS_URL=nats://localhost:4222

# Node identifier (defaults to hostname if unset in binary)
SPARK_NODE_ID=spark-node

# Directory to watch for Kubernetes manifests
SPARK_MANIFEST_DIR=/etc/spark/manifests

# Max concurrent GPU pods
SPARK_GPU_MAX=1

# Heartbeat publish interval
SPARK_HEARTBEAT_INTERVAL=10s

# Reconciliation loop interval
SPARK_RECONCILE_INTERVAL=5s

# CPU millicores reserved for system
SPARK_SYSTEM_RESERVE_CPU=2000

# MB of RAM reserved for system
SPARK_SYSTEM_RESERVE_MEMORY=4096

# Cores reserved for system (e.g. "0-1" or "0,1"). Empty disables cpuset
# pinning entirely; pods then run with --cpus quota only (default behaviour
# pre-v1.9.0). When set, integer-CPU pods are pinned via --cpuset-cpus and
# the cores listed here are excluded from allocation. See ADR-012 and #22.
SPARK_SYSTEM_RESERVE_CORES=

# SQLite state database path
SPARK_STATE_DB=/var/lib/spark/state.db

# Retention for completed/failed pods (7 days)
SPARK_POD_RETENTION=168h

# HTTP API listen address
SPARK_HTTP_ADDR=:8080

# Graceful shutdown timeout
SPARK_SHUTDOWN_TIMEOUT=30s

# Resource reconciliation interval
SPARK_RECONCILE_RESOURCES_INTERVAL=60s
